# Copie este arquivo para ".env" e ajuste os valores para o seu ambiente local.
# O helper de conexão (Infrastructure/DatabaseUrlParser) exige DATABASE_URL definida.

# --- Uso com `dotnet run` direto (sem Docker) ---------------------------------------
# String no formato URI do Postgres (é o mesmo formato que o Railway injeta em produção).
DATABASE_URL=postgresql://orcalar:orcalar@localhost:5432/orcalar

# Porta em que a API escuta (Railway injeta PORT automaticamente; fallback local = 8080).
PORT=8080

# --- Uso com `docker compose up` -----------------------------------------------------
# O docker-compose.yml monta a própria DATABASE_URL (apontando para o serviço "db") a
# partir destas três variáveis — não precisa duplicar a URI acima para o Docker.
POSTGRES_USER=orcalar
POSTGRES_PASSWORD=orcalar
POSTGRES_DB=orcalar
